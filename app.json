{
  "expo": {
    "name": "Insta News Telugu",
    "slug": "telugu-news-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/launcher-icon.png",
    "scheme": "telugu-news-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/native-splash-blank.png",
      "imageWidth": 220,
      "resizeMode": "contain",
      "backgroundColor": "#0B0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.telugu.enewspaper"
    },
    "android": {
      "package": "com.telugu.enewspaper",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/launcher-adaptive-foreground.png",
        "backgroundColor": "#0B0F14"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0a9b9a",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "androidNavigationBar": {
      "backgroundColor": "#0B0F14",
      "barStyle": "light-content"
    }
  }
}
