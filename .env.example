# Public values embedded in Expo client builds.
# Keep service-role keys, DB URLs, access tokens, and private API keys out of this file.
EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-rotated-public-anon-key
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXXX.ingest.sentry.io/XXXXXXX
EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
