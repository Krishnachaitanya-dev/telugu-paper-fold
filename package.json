{
  "name": "telugu-news-mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --localhost --port 8081",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android --clean --no-install",
    "build:apk": "cd android && ./gradlew assembleRelease --no-daemon",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ios": "expo run:ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "load-test": "k6 run scripts/load-test.js -e SUPABASE_URL=$SUPABASE_URL -e SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "54.0.23",
    "@expo/vector-icons": "^15.1.1",
    "@playwright/test": "^1.60.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^54.0.0",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "jsdom": "^29.1.1",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@sentry/react-native": "^8.13.0",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "~54.0.34",
    "expo-device": "^8.0.10",
    "expo-file-system": "~19.0.17",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "^0.32.17",
    "posthog-react-native": "^4.46.12",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "^15.15.5",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.6.3"
}
